<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pettrail.pettrailbackend.mapper.CheckinStatsMapper">

    <resultMap id="BaseResultMap" type="com.pettrail.pettrailbackend.entity.CheckinStats">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="item_id" property="itemId"/>
        <result column="total_count" property="totalCount"/>
        <result column="current_streak" property="currentStreak"/>
        <result column="max_streak" property="maxStreak"/>
        <result column="last_checkin_date" property="lastCheckinDate"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 根据用户 ID 和打卡项 ID 查询统计 -->
    <select id="selectByUserIdAndItemId" resultMap="BaseResultMap">
        SELECT * FROM checkin_stats
        WHERE user_id = #{userId}
        AND item_id = #{itemId}
        LIMIT 1
    </select>

</mapper>
