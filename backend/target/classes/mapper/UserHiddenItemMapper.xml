<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pettrail.pettrailbackend.mapper.UserHiddenItemMapper">

    <select id="selectHiddenItemIdsByUserId" resultType="java.lang.Long">
        SELECT item_id FROM user_hidden_items
        WHERE user_id = #{userId}
    </select>

</mapper>
