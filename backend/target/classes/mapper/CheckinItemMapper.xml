<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pettrail.pettrailbackend.mapper.CheckinItemMapper">

    <resultMap id="BaseResultMap" type="com.pettrail.pettrailbackend.entity.CheckinItem">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="icon" property="icon"/>
        <result column="type" property="type"/>
        <result column="description" property="description"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="is_default" property="isDefault"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 查询默认打卡项 -->
    <select id="selectDefaultItems" resultMap="BaseResultMap">
        SELECT * FROM checkin_items
        WHERE is_default = 1
        AND is_enabled = 1
        ORDER BY sort_order ASC
    </select>

    <!-- 查询用户自定义打卡项 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM checkin_items
        WHERE user_id = #{userId}
        AND is_enabled = 1
        ORDER BY sort_order ASC
    </select>

</mapper>
