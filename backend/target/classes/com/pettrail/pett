package com.pettrail.pettrailbackend.controller;

import com.pettrail.pettrailbackend.entity.HealthRecord;
import com.pettrail.pettrailbackend.service.HealthRecordService;
import lombok.RequiredArgsConstructor;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
@RequestMapping("/api/health")
@RequiredArgsConstructor
public class HealthController {

    private final HealthRecordService healthRecordService;

    @GetMapping("/overview")
    public Map<String, Object> getOverview() {
        Map<String, Object> result = new HashMap<>();
        result.put("success", true);
        result.put("data", healthRecordService.getOverview());
        result.put("message", "获取成功");
        return result;
    }

    @GetMapping("/weight-records")
    public Map<String, Object> getWeightRecords(@RequestParam Long petId) {
        Map<String, Object> result = new HashMap<>();
        try {
            List<HealthRecord> records = healthRecordService.getWeightRecords(petId);
            result.put("success", true);
            result.put("data", records);
            result.put("message", "获取成功");
        } catch (Exception e) {
            result.put("success", false);
            result.put("message", "获取失败: " + e.getMessage());
        }
        return result;
    }

    @GetMapping("/vaccine-reminders")
    public Map<String, Object> getVaccineReminders(@RequestParam Long petId) {
        Map<String, Object> result = new HashMap<>();
        try {
            List<HealthRecord> records = healthRecordService.getVaccineReminders(petId);
            result.put("success", true);
            result.put("data", records);
            result.put("message", "获取成功");
        } catch (Exception e) {
            result.put("success", false);
            result.put("message", "获取失败: " + e.getMessage());
        }
        return result;
    }
}
