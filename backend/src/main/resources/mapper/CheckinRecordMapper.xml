<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pettrail.pettrailbackend.mapper.CheckinRecordMapper">

    <resultMap id="BaseResultMap" type="com.pettrail.pettrailbackend.entity.CheckinRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="pet_id" property="petId"/>
        <result column="item_id" property="itemId"/>
        <result column="record_date" property="recordDate"/>
        <result column="status" property="status"/>
        <result column="note" property="note"/>
        <result column="images" property="images"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 根据用户 ID 和日期范围查询打卡记录 -->
    <select id="selectByUserIdAndDateRange" resultMap="BaseResultMap">
        SELECT * FROM checkin_records_202401
        WHERE user_id = #{userId}
        AND record_date BETWEEN #{startDate} AND #{endDate}
        ORDER BY record_date DESC, created_at DESC
    </select>

    <!-- 查询用户某日的打卡记录 -->
    <select id="selectByUserIdAndDate" resultMap="BaseResultMap">
        SELECT * FROM checkin_records_202401
        WHERE user_id = #{userId}
        AND record_date = #{date}
        ORDER BY created_at DESC
    </select>

    <!-- 检查用户某日是否已打卡 -->
    <select id="selectByUserIdItemIdAndDate" resultMap="BaseResultMap">
        SELECT * FROM checkin_records_202401
        WHERE user_id = #{userId}
        AND item_id = #{itemId}
        AND record_date = #{date}
        LIMIT 1
    </select>

</mapper>
