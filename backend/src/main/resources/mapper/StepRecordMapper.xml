<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pettrail.pettrailbackend.mapper.StepRecordMapper">

    <resultMap id="BaseResultMap" type="com.pettrail.pettrailbackend.entity.StepRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="pet_id" property="petId"/>
        <result column="steps" property="steps"/>
        <result column="distance" property="distance"/>
        <result column="record_date" property="recordDate"/>
        <result column="source" property="source"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 根据用户 ID、宠物 ID 和日期查询步数记录 -->
    <select id="selectByUserIdPetIdDate" resultMap="BaseResultMap">
        SELECT * FROM step_records
        WHERE user_id = #{userId}
        AND pet_id = #{petId}
        AND record_date = #{date}
        LIMIT 1
    </select>

    <!-- 查询步数趋势 -->
    <select id="selectTrend" resultMap="BaseResultMap">
        SELECT * FROM step_records
        WHERE user_id = #{userId}
        AND pet_id = #{petId}
        AND record_date BETWEEN #{startDate} AND #{endDate}
        ORDER BY record_date ASC
    </select>

</mapper>
