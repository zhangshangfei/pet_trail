# ======================
# 宠迹项目环境变量配置
# ======================
# 复制此文件为 .env 并填入实际值

# ----------------------
# 数据库配置
# ----------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=pet_trail
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# ----------------------
# Redis 配置
# ----------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ----------------------
# 微信配置
# ----------------------
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_APP_SECRET=

# ----------------------
# JWT 配置
# ----------------------
# 可以使用以下命令生成：openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION=604800

# ----------------------
# 腾讯云 COS 配置
# ----------------------
TENCENT_COS_BUCKET_NAME=
TENCENT_COS_REGION=ap-shanghai
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=

# ----------------------
# 服务器配置
# ----------------------
SERVER_PORT=8080
