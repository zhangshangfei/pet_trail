# ======================
# 宠迹项目 - Docker Compose 环境变量
# ======================
# 复制此文件为 .env 并按需修改

# ----------------------
# 数据库配置
# ----------------------
MYSQL_ROOT_PASSWORD=
MYSQL_PORT=3306
MYSQL_DATABASE=pet_trail
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# ----------------------
# Redis 配置
# ----------------------
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ----------------------
# 腾讯云 COS 配置
# ----------------------
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET_NAME=
TENCENT_COS_REGION=ap-shanghai

# ----------------------
# JWT 配置
# ----------------------
JWT_SECRET=

# ----------------------
# 微信小程序配置
# ----------------------
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_APP_SECRET=

# ----------------------
# AI 分析配置
# ----------------------
AI_ENABLED=true
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openrouter/free
AI_GLM_ENABLED=true
AI_GLM_API_KEY=
AI_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_GLM_MODEL=glm-4.7-flash

# ----------------------
# RabbitMQ 配置（可选，默认关闭）
# ----------------------
RABBITMQ_ENABLED=false

# ----------------------
# 服务器配置
# ----------------------
SERVER_PORT=8080
