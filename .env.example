# ======================
# 宠迹项目 - Docker Compose 环境变量
# ======================
# 复制此文件为 .env 并填入实际值

# ----------------------
# 数据库配置
# ----------------------
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_PORT=3306
MYSQL_DATABASE=pet_trail
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password

# ----------------------
# Redis 配置
# ----------------------
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=0

# ----------------------
# 腾讯云 COS 配置
# ----------------------
TENCENT_COS_SECRET_ID=your_cos_secret_id
TENCENT_COS_SECRET_KEY=your_cos_secret_key
TENCENT_COS_BUCKET_NAME=your_cos_bucket_name
TENCENT_COS_REGION=ap-shanghai

# ----------------------
# JWT 配置
# ----------------------
# 可以使用以下命令生成：openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key

# ----------------------
# 微信小程序配置
# ----------------------
WECHAT_MINIAPP_APP_ID=your_wechat_app_id
WECHAT_MINIAPP_APP_SECRET=your_wechat_app_secret

# ----------------------
# AI 分析配置
# ----------------------
AI_ENABLED=true
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openrouter/free
AI_GLM_ENABLED=true
AI_GLM_API_KEY=your_glm_api_key
AI_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_GLM_MODEL=glm-4.7-flash

# ----------------------
# RabbitMQ 配置（可选，默认关闭）
# ----------------------
RABBITMQ_ENABLED=false
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ----------------------
# 服务器配置
# ----------------------
SERVER_PORT=8080
