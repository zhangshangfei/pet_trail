# ======================
# 宠迹项目环境变量配置
# ======================
# 复制此文件为 .env 并填入实际值

# ----------------------
# 数据库配置
# ----------------------
MYSQL_PASSWORD=root123654

# ----------------------
# 微信配置
# ----------------------
# 微信小程序 AppID
WECHAT_MINIAPP_APP_ID=wxb210d75568abe1f7
# 微信小程序 AppSecret (请在微信公众平台获取)
WECHAT_MINIAPP_APP_SECRET=your-app-secret-here

# ----------------------
# JWT 配置
# ----------------------
# JWT 密钥（至少 256 位，建议使用随机生成的字符串）
# 可以使用以下命令生成：openssl rand -base64 32
JWT_SECRET=pet-trail-secret-key-change-this-in-production

# ----------------------
# 腾讯云 COS 配置 (微信云托管推荐)
# ----------------------
TENCENT_COS_SECRET_ID=your-secret-id
TENCENT_COS_SECRET_KEY=your-secret-key

# ----------------------
# Redis 配置（可选，默认本地）
# ----------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------
# RabbitMQ 配置（可选）
# ----------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ----------------------
# 服务器配置
# ----------------------
SERVER_PORT=8080
