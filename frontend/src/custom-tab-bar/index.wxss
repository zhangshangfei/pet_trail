.tabbar-safe {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
}

.tabbar {
  margin: 0 24rpx 18rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 60rpx;
  box-shadow:
    0 8rpx 32rpx rgba(31, 38, 135, 0.2),
    0 2rpx 8rpx rgba(0, 0, 0, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.05);
  display: block;
  position: relative;
  padding: 0 16rpx;
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

/* 顶部高光线 */
.tabbar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 20%;
  right: 20%;
  height: 1rpx;
  background: linear-gradient(90deg,
    transparent,
    rgba(255, 255, 255, 1),
    transparent
  );
  pointer-events: none;
}

.tabbar-items {
  height: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
  position: relative;
  z-index: 5;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  position: relative;
}

.tabbar-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  background: transparent;
}

/* 活跃状态背景光晕 */
.tabbar-item.active .tabbar-icon-wrap {
  background: radial-gradient(
    circle at center,
    rgba(255, 106, 61, 0.25) 0%,
    rgba(255, 106, 61, 0.08) 60%,
    transparent 100%
  );
  box-shadow:
    0 0 20rpx rgba(255, 106, 61, 0.15),
    inset 0 0 12rpx rgba(255, 106, 61, 0.1);
  transform: scale(1.05);
}

.tabbar-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  filter: grayscale(30%);
}

.tabbar-item.active .tabbar-icon {
  filter: grayscale(0%);
  transform: scale(1.1);
}

.tabbar-text {
  font-size: 22rpx;
  line-height: 22rpx;
  font-weight: 500;
  margin-top: 4rpx;
  transition: all 0.3s ease;
  letter-spacing: 0.5rpx;
}

.tabbar-item.active {
  color: #ff6a3d;
}

.tabbar-item.active .tabbar-text {
  font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(255, 106, 61, 0.3);
}

/* Hover 效果 */
.tabbar-item:hover:not(.active) {
  color: #6b7280;
}

.tabbar-item:hover:not(.active) .tabbar-icon-wrap {
  background: rgba(156, 163, 175, 0.1);
  transform: scale(1.02);
}

/* 按压反馈 */
.tabbar-item:active .tabbar-icon-wrap {
  transform: scale(0.92) !important;
  transition-duration: 0.1s;
}

.tabbar-item:active:not(.active) .tabbar-icon-wrap {
  background: rgba(156, 163, 175, 0.15);
}

/* Home icon - house shape */
.icon-home {
  width: 28rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-radius: 4rpx 4rpx 0 0;
  position: relative;
}
.icon-home::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 14rpx solid currentColor;
}
.icon-home::after {
  content: '';
  position: absolute;
  bottom: -3rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 2rpx 2rpx;
}

/* Health icon - heart shape */
.icon-health {
  width: 26rpx;
  height: 24rpx;
  position: relative;
}
.icon-health::before {
  content: '';
  position: absolute;
  top: 0;
  left: 2rpx;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-radius: 50% 50% 0 0;
  transform: rotate(-45deg);
  transform-origin: right bottom;
}
.icon-health::after {
  content: '';
  position: absolute;
  top: 0;
  right: 2rpx;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-radius: 50% 50% 0 0;
  transform: rotate(45deg);
  transform-origin: left bottom;
}

/* Checkin icon - checkmark in circle */
.icon-checkin {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  position: relative;
}
.icon-checkin::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 8rpx;
  width: 10rpx;
  height: 6rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(-45deg);
}

/* Me icon - person shape */
.icon-me {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}
.icon-me::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}
.icon-me::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 22rpx;
  height: 10rpx;
  border: 3rpx solid currentColor;
  border-radius: 10rpx 10rpx 0 0;
}

/* 暗色主题适配 */
page.dark .tabbar {
  background: rgba(30, 30, 45, 0.85);
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.5),
    0 2rpx 8rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.2);
  border-color: rgba(255, 255, 255, 0.08);
}

page.dark .tabbar::before {
  background: linear-gradient(90deg,
    transparent,
    rgba(255, 255, 255, 0.15),
    transparent
  );
}

page.dark .tabbar-item {
  color: #6b7280;
}

page.dark .tabbar-item.active .tabbar-icon-wrap {
  background: radial-gradient(
    circle at center,
    rgba(255, 106, 61, 0.3) 0%,
    rgba(255, 106, 61, 0.1) 60%,
    transparent 100%
  );
  box-shadow:
    0 0 24rpx rgba(255, 106, 61, 0.2),
    inset 0 0 12rpx rgba(255, 106, 61, 0.15);
}