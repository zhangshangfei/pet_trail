.tabbar-safe {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
}

.tabbar {
  margin: 0 24rpx 18rpx;
  height: 124rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 64rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.12);
  display: block;
  position: relative;
  padding: 0 26rpx;
  backdrop-filter: blur(16rpx);
}

.tabbar-items {
  height: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8b93a6;
}

.tabbar-icon {
  font-size: 40rpx;
  line-height: 40rpx;
  margin-bottom: 10rpx;
}

.tabbar-text {
  font-size: 24rpx;
  line-height: 24rpx;
  font-weight: 600;
}

.tabbar-item.active {
  color: #ff6a3d;
}

